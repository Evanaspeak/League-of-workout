# ─── Base de données (Supabase Postgres) ──────────────────────────────────
# DATABASE_URL : connexion "pooled" (port 6543, pgBouncer) pour l'app
# DIRECT_URL   : connexion directe (port 5432) pour les migrations Prisma
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ─── Auth.js (NextAuth) ────────────────────────────────────────────────────
# Généré avec : npx auth secret   (ou openssl rand -base64 33)
AUTH_SECRET="..."
# En prod, l'URL publique du site (ex: https://leagueofworkouts.com)
AUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com (API & Services > Credentials)
# Redirect URI autorisée : {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID="..."
AUTH_GOOGLE_SECRET="..."

# Discord OAuth — https://discord.com/developers/applications (OAuth2)
# Redirect URI autorisée : {AUTH_URL}/api/auth/callback/discord
AUTH_DISCORD_ID="..."
AUTH_DISCORD_SECRET="..."

# ─── Riot Games API ────────────────────────────────────────────────────────
RIOT_API_KEY="RGAPI-..."
