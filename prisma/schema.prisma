generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String  @id @default(cuid())
  pseudo        String  @default("Joueur")
  riotId        String? // format: pseudo#tag
  riotPuuid     String?
  riotRegion    String  @default("EUW1")
  gainageMaxSec Int     @default(45)
  games         Game[]
  Goal          Goal?
}

model Game {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  date                DateTime @default(now())
  role                String   // Top | Jungle | Mid | ADC | Support | ARAM | Arena
  champion            String?
  kills               Int
  deaths              Int
  assists             Int
  result              String   // V | D
  gainageSec          Int
  niveauCalcule       Int
  partiesAvantCalcule Int
  surchargeCalculee   Float
  scoreCalcule        Int
  malusCalcule        Int
  pompesCalculees     Int
  source              String   @default("manuel") // manuel | riot_api
  riotMatchId         String?
}

model RoleWeight {
  role           String  @id // Top | Jungle | Mid | ADC | Support | ARAM | Arena
  poidsMort      Float
  poidsKill      Float
  poidsAssist    Float
  maitriseActive Boolean
}

model LevelConfig {
  niveau         Int   @id // 1-5
  seuilGainageSec Int  // seuil max en secondes
  multiplicateur Float
  malusDefaite   Int
}

model MasteryConfig {
  id             Int   @id @default(1)
  surchargeMax   Float @default(0.5)
  partiesPourMax Int   @default(100)
}

model Goal {
  id                   String @id @default(cuid())
  userId               String @unique
  user                 User   @relation(fields: [userId], references: [id])
  objectifTotalPompes  Int    @default(1000)
}
